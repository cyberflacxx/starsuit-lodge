generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  BRANCH_ADMIN
  RECEPTIONIST
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  BLOCKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MOCK_ECOCASH
  PAYNOW
  BANK_TRANSFER
  CASH
  PROOF_OF_PAYMENT
}

enum TransportOption {
  OWN_CAR
  NEED_PICKUP
  NO_TRANSPORT_SUPPORT
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT_UPDATE
  BOOKING_STATUS_CHANGE
  ROOM_STATUS_CHANGE
}

model Branch {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String
  address       String
  city          String
  phone         String
  email         String
  mapUrl        String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  rooms         Room[]
  bookings      Booking[]
  admins        AdminUser[]
  galleryImages GalleryImage[]
  services      Service[]
  contentBlocks ContentBlock[]
}

model RoomType {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  basePrice   Decimal   @db.Decimal(10, 2)
  capacity    Int
  bedType     String
  amenities   String[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  rooms       Room[]
  bookings    Booking[]
}

model Room {
  id                String                 @id @default(cuid())
  branchId          String
  roomTypeId        String
  roomNumber        String
  floor             Int?
  status            RoomStatus             @default(AVAILABLE)
  notes             String?
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  branch            Branch                 @relation(fields: [branchId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  roomType          RoomType               @relation(fields: [roomTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  bookings          Booking[]
  maintenanceBlocks RoomMaintenanceBlock[]

  @@unique([branchId, roomNumber])
}

model Guest {
  id        String    @id @default(cuid())
  firstName String
  surname   String
  idNumber  String
  gender    Gender
  phone     String
  email     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]

  @@index([phone])
  @@index([email])
  @@index([idNumber])
}

model Booking {
  id                  String          @id @default(cuid())
  bookingReference    String          @unique
  branchId            String
  roomTypeId          String
  roomId              String?
  guestId             String
  checkInDate         DateTime
  checkOutDate        DateTime
  expectedArrivalTime DateTime
  numberOfGuests      Int
  isBookingForTwo     Boolean         @default(false)
  transportOption     TransportOption @default(NO_TRANSPORT_SUPPORT)
  hasOwnCar           Boolean         @default(false)
  needsParking        Boolean         @default(false)
  needsPickup         Boolean         @default(false)
  pickupPoint         String?
  specialRequests     String?
  status              BookingStatus   @default(PENDING)
  totalAmount         Decimal         @db.Decimal(10, 2)
  paymentStatus       PaymentStatus   @default(UNPAID)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  cancelledAt         DateTime?
  cancellationReason  String?
  branch              Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  roomType            RoomType        @relation(fields: [roomTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  room                Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  guest               Guest           @relation(fields: [guestId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  payment             Payment?
  auditLogs           AuditLog[]

  @@index([branchId])
  @@index([roomTypeId])
  @@index([roomId])
  @@index([guestId])
  @@index([checkInDate])
  @@index([checkOutDate])
  @@index([status])
  @@index([paymentStatus])
}

model Payment {
  id                   String        @id @default(cuid())
  bookingId            String        @unique
  method               PaymentMethod
  status               PaymentStatus @default(PENDING)
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("USD")
  transactionReference String?
  providerReference    String?
  paidAt               DateTime?
  failureReason        String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  booking              Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model AdminUser {
  id             String     @id @default(cuid())
  email          String     @unique
  fullName       String
  role           UserRole
  branchId       String?
  supabaseUserId String?    @unique
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  branch         Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  auditLogs      AuditLog[]
}

model GalleryImage {
  id         String   @id @default(cuid())
  branchId   String?
  title      String
  altText    String
  imageUrl   String
  sortOrder  Int      @default(0)
  isFeatured Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  branch     Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model Service {
  id          String   @id @default(cuid())
  branchId    String?
  title       String
  description String
  iconName    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model ContentBlock {
  id        String        @id @default(cuid())
  branchId  String?
  key       String
  title     String
  body      String
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  branch    Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([key, branchId])
}

model RoomMaintenanceBlock {
  id        String   @id @default(cuid())
  roomId    String
  startDate DateTime
  endDate   DateTime
  reason    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([roomId])
  @@index([startDate])
  @@index([endDate])
}

model AuditLog {
  id          String      @id @default(cuid())
  adminUserId String?
  bookingId   String?
  action      AuditAction
  entity      String
  entityId    String?
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  adminUser   AdminUser?  @relation(fields: [adminUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  booking     Booking?    @relation(fields: [bookingId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([adminUserId])
  @@index([bookingId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}
